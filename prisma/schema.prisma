// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  ordererName       String
  ordererPhone      String
  businessName      String?
  businessRegNumber String?
  businessRegCertUrl String?
  shippingAddress   String
  shippingDetail    String?
  requestNotes      String?
  
  productName       String
  quantity          Int
  contractMonths    Int
  monthlyFee        Int
  totalAmount       Int
  
  status            String   @default("PENDING") // PENDING, PARTIALLY_PAID, PAID, CANCELLED, ABNORMAL_CANCELLED
  
  paymentExpiresAt  DateTime?
  isAbnormalCancel  Boolean   @default(false)
  cancelReason      String?
  
  transactions      PaymentTransaction[]
  
  installationDate  String?
  adminManager      String?
  adminNotes        String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PaymentTransaction {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  amount          Int
  method          String   // "CARD", "VIRTUAL_ACCOUNT"
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED, CANCELLED
  
  pgTid           String?
  pgAppDate       String?
  pgAppNo         String?
  cardCompanyName String?
  quota           Int?
  
  cancelAmount    Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
